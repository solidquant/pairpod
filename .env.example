# Config lives in ~/.pairpod/.env (override the dir with PAIRPOD_HOME).
# The easiest way to create it is: pairpod onboard
# This file documents every supported key.

# Telegram bot token from @BotFather (required).
TELEGRAM_BOT_TOKEN=
# Comma-separated @handles allowed to use the bot + mini app (blank = anyone).
# The first private message from an allowed @handle pins its numeric id here
# automatically (ids can't be reassigned; usernames can).
TELEGRAM_ALLOWED_USERNAMES=
TELEGRAM_ALLOWED_USER_IDS=

# Port the bot + mini-app server listens on.
PORT=40002

# Allow Host pods — an UNSANDBOXED shell on the bot machine. Off by default.
# Docker and SSH pods are isolated; Host is not. `pairpod start --host-mode true`
# overrides this for a single run.
HOST_MODE=false

# Public https origin Telegram loads the mini app from. `pairpod start` sets this
# automatically from the tunnel it launches; set it yourself only for a fixed URL.
MINIAPP_URL=
# Open terminals from GROUP chats via a direct-link mini app (web_app buttons are
# private-chat only). Pick ONE:
#   MINIAPP_MAIN=true                — use the bot's Main Mini App (BotFather: Bot Settings →
#                                      Configure Mini App). Link: t.me/<bot>?startapp=… . No
#                                      photo/short-name needed. Recommended.
#   MINIAPP_APP_SHORT_NAME=<name>    — use a /newapp short name. Link: t.me/<bot>/<name>?startapp=…
# Blank/false on both = private-chat web_app buttons only. Either way the BotFather Mini App
# URL must equal MINIAPP_URL, so a STABLE MINIAPP_URL is needed (the quick-tunnel rotates).
MINIAPP_APP_SHORT_NAME=
MINIAPP_MAIN=
# Max age (seconds) of Telegram initData accepted on the attach WebSocket.
MINIAPP_AUTH_MAX_AGE_SEC=86400

# Master key for the SSH credential vault (AES-256-GCM, base64 of 32 bytes).
# `pairpod onboard` generates one automatically.
PAIRPOD_VAULT_KEY=

# Docker (optional — only for Docker pods).
DOCKER_SOCKET=/var/run/docker.sock
PAIRPOD_NETWORK=pairpod-net
LOG_LEVEL=info
