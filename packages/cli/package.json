{
  "name": "pairpod",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "description": "Run terminals and Claude Code sessions from your phone via a Telegram bot, on Docker, SSH, or host backends.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidquant/pairpod.git",
    "directory": "packages/cli"
  },
  "keywords": [
