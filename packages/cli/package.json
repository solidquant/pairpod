    "claude-code",
    "claude",
    "terminal",
    "web-terminal",
    "ssh",
    "docker",
    "tmux",
    "pty",
    "mobile",
    "self-hosted",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "pairpod": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsc"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "pairpod-bot": "workspace:*"
